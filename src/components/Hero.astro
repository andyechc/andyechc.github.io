---
import { Image } from 'astro:assets';

export interface Props {
  name: string;
  title: string;
  description: string;
  avatar: string;
  social: Array<{
    name: string;
    url: string;
    icon: string;
  }>;
}

const { name, title, description, avatar, social } = Astro.props;
---

<section class="min-h-screen flex items-center justify-center bg-black text-white">
  <div class="container mx-auto px-4 py-20">
    <div class="flex flex-col items-center text-center space-y-8">
      <!-- Avatar -->
      <div class="flex-shrink-0">
        <Image 
          src={avatar} 
          alt={name}
          width={192}
          height={192}
          class="w-32 h-32 md:w-48 md:h-48 rounded-full object-cover border-4 border-accent shadow-2xl"
          loading="eager"
        />
      </div>
      
      <!-- Hero Content -->
      <div class="space-y-6">
        <h1 class="text-3xl md:text-5xl font-bold text-white">
          {name}
        </h1>
        
        <h2 class="text-xl md:text-2xl text-accent">
          {title}
        </h2>
        
        <p class="text-base md:text-lg text-gray-400 max-w-2xl">
          {description}
        </p>
        
        <!-- Social Links -->
        <div class="flex justify-center space-x-6">
          {social.map((socialLink) => (
            <a 
              href={socialLink.url}
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 bg-gray-800 rounded-2xl hover:bg-accent transition-colors duration-200"
              aria-label={socialLink.name}
            >
              <i class={`${socialLink.icon} text-2xl p-1`}></i>
            </a>
          ))}
        </div>
        
        <!-- Contact Button -->
        <div class="pt-4">
          <a 
            href="#contact"
            class="inline-flex items-center px-8 py-3 bg-accent text-black font-medium rounded-[2rem] hover:bg-accent/80 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent"
          >
            Contactar
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  section {
    animation: fadeInUp 1s ease-out;
  }
  
  h1, h2, p {
    animation-delay: 0.2s;
  }
  
  .flex > div:last-child > div:last-child {
    animation-delay: 0.4s;
  }
</style>
